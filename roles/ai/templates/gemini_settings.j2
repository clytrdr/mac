{
  "context": {
    "fileName": "AGENTS.md"
  },
  "mcpServers": {
{% for server in ai_mcp_servers %}
    "{{ server.name }}": {
{% if server.url is defined %}
      "url": "{{ server.url }}"
{% else %}
      "command": "{{ server.command }}",
      "args": {{ server.args | to_json }}
{%- if server.env is defined %},
      "env": {{ server.env | to_json }}
{%- endif %}

{% endif %}
    }{% if not loop.last %},{% endif %}

{% endfor %}
  },
  "general": {
    "preferredEditor": "vim",
    "previewFeatures": true,
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "30d"
    }
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "theme": "ANSI",
    "footer": {
      "hideModelInfo": false
    },
    "showModelInfoInChat": true
  },
  "hasSeenIdeIntegrationNudge": true,
  "ide": {
    "hasSeenNudge": true
  }
}
