{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(gcloud:*)",
      "Bash(terraform:*)",
      "Bash(docker:*)",
      "Bash(ansible:*)",
      "Bash(ansible-playbook:*)",
      "Bash(ansible-lint:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(uv:*)",
      "Bash(python:*)",
      "Bash(pytest:*)",
      "Bash(pre-commit:*)",
      "Bash(mkdir:*)",
      "Bash(brew:*)",
      "Bash(cat:*)",
      "Bash(rg:*)",
      "Bash(playwright-cli:*)",
      "Bash(mv:*)",
      "Bash(open:*)",
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "mcp__context7__*",
      "mcp__jetbrains__*",
      "mcp__terraform__*",
      "mcp__firecrawl__*"
    ],
    "deny": [],
    "additionalDirectories": [
      "{{ ansible_facts.env.HOME }}/Code"
    ]
  },
  "enabledPlugins": {
{% for plugin in ai_claude_plugins %}
    "{{ plugin.name }}@{{ plugin.marketplace }}": true{{ "," if not loop.last else "" }}
{% endfor %}
  },
  "extraKnownMarketplaces": {
{% for mp in ai_claude_plugin_marketplaces %}
    "{{ mp.name }}": {
      "source": {
        "source": "github",
        "repo": "{{ mp.source }}"
      }
    }{{ "," if not loop.last else "" }}
{% endfor %}
  },
  "effortLevel": "{{ ai_claude_effort_level }}",
  "env": {
{% for k, v in ai_claude_env.items() %}
    "{{ k }}": "{{ v }}"{{ "," if not loop.last else "" }}
{% endfor %}
  }
}
