# ~/.codex/config.toml — Managed by Ansible (roles/ai)
# Reference: https://developers.openai.com/codex/config-basic
{% for path in ai_codex_trusted_projects %}

[projects."{{ path }}"]
trust_level = "trusted"
{% endfor %}

[tui.model_availability_nux]
{% for model, count in ai_codex_tui_model_nux.items() %}
"{{ model }}" = {{ count }}
{% endfor %}
{% for server in ai_mcp_servers %}
{% set codex_server = server.codex | default(server) %}
{% set codex_env = codex_server.env | default(server.env | default({})) %}

[mcp_servers.{{ server.name }}]
{% if codex_server.url is defined %}
url = {{ codex_server.url | to_json }}
{% else %}
command = {{ codex_server.command | to_json }}
args = {{ codex_server.args | to_json }}
{% endif %}
{% if codex_env %}

[mcp_servers.{{ server.name }}.env]
{% for k, v in codex_env.items() %}
{{ k }} = {{ v | to_json }}
{% endfor %}
{% endif %}
{% endfor %}
